# ==========================================
# BetTraction - Environment Variables Example
# ==========================================

# ==========================================
# NODE
# ==========================================
NODE_ENV=development

# ==========================================
# API
# ==========================================
API_PORT=3000
API_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=v1

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bettraction

# ==========================================
# JWT
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# WEB3
# ==========================================
NETWORK_NAME=Base Mainnet
NETWORK_CHAIN_ID=8453
NETWORK_RPC_URL=https://mainnet.base.org
NETWORK_EXPLORER_URL=https://basescan.org
VAULT_WALLET_ADDRESS=0xc1A020BE6548D70319a31060E32f1E2A8Cf8d930
COINGECKO_API_KEY=your-coingecko-api-key

# ==========================================
# WEB
# ==========================================
WEB_PORT=5173
WEB_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
VITE_WALLET_CONNECT_PROJECT_ID=your-wallet-connect-project-id

# ==========================================
# ADMIN
# ==========================================
ADMIN_PORT=5174
ADMIN_URL=http://localhost:5174
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-production

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# SENTRY
# ==========================================
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ==========================================
# EMAIL
# ==========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@bettraction.com

# ==========================================
# STORAGE
# ==========================================
S3_BUCKET=bettraction-files
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
